# Skripten (Dockerfile, synology-spk/build_spk.sh, postinst) selbst
# angelegt, muss also nicht extra über .gitkeep-Dateien versioniert werden.
uploads/

# Echte Datenbank-Backups (enthalten Klarnamen, Beträge, Adressen)
backups/*.sql

