# Echte Zugangsdaten - niemals commiten, siehe config/config.example.php
config/config.php

# Docker-Zugangsdaten (lokal generiert von start.bat/start.sh)
.env

# Echte Nutzdaten (Mieterdokumente, Rechnungen, Übergabeprotokolle) -
