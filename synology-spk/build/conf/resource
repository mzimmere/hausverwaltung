{
    "webservice": {
        "services": [{
            "service": "hausverwaltung",
            "display_name": "Hausverwaltung",
            "support_alias": true,
            "support_server": true,
            "type": "apache_php",
            "root": "hausverwaltung",
            "backend": 7,
            "icon": "PACKAGE_ICON_256.PNG",
            "php": {
                "profile_name": "Hausverwaltung Profile",
                "profile_desc": "PHP-Profil für die Hausverwaltung",
                "backend": 7,
                "open_basedir": "/var/services/web_packages/hausverwaltung:/tmp:/var/services/tmp",
                "extensions": ["pdo", "pdo_mysql", "mysqli", "fileinfo", "mbstring", "gd", "zip", "curl"],
                "php_settings": {
                    "mysqli.default_socket": "/run/mysqld/mysqld10.sock",
                    "pdo_mysql.default_socket": "/run/mysqld/mysqld10.sock",
                    "display_errors": "0",
                    "error_reporting": "E_ALL",
                    "log_errors": "true"
                },
                "user": "HausVerwaltung",
                "group": "http"
            },
            "connect_timeout": 60,
            "read_timeout": 3600,
            "send_timeout": 60
        }],
        "portals": [{
            "service": "hausverwaltung",
            "type": "alias",
            "name": "hausverwaltung",
            "alias": "hausverwaltung"
        }],
        "pkg_dir_prepare": [{
            "source": "/var/packages/HausVerwaltung/target/app",
            "target": "hausverwaltung",
            "mode": "0755",
            "user": "HausVerwaltung",
            "group": "http"
        }]
    }
}
