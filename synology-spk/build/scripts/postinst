#!/bin/sh
# Die App-Dateien wurden bereits vom Webservice-Worker nach
# /var/services/web_packages/hausverwaltung kopiert (siehe conf/resource,
# pkg_dir_prepare) - das Paket selbst braucht dafür keine Root-Rechte.
#
# Hinweis: Dies ist immer eine FRISCHE, eigenständige Installation mit
# eigener Datenbank - keine bestehende Installation wird dabei verändert
# oder zusammengeführt (andere Speicherorte).

{
    echo "Hausverwaltung wurde installiert - ein letzter Schritt fehlt noch:"
    echo ""
    echo "1. phpMyAdmin oeffnen (falls noch nicht installiert: Paket-Zentrum)"
    echo "2. Reiter 'Importieren' -> Datei auswaehlen (per File Station unter"
    echo "   'web_packages' -> 'hausverwaltung'):"
    echo "   EINMALIG_IN_PHPMYADMIN_AUSFUEHREN.sql"
    echo "3. Auf 'OK'/'Los' klicken, danach die Datei loeschen"
    echo ""
    echo "Danach: http://$(hostname)/hausverwaltung/"
    echo "Login: admin / hausverwaltung (bitte sofort nach dem ersten Login aendern)"
} > "$SYNOPKG_TEMP_LOGFILE" 2>/dev/null || true

exit 0
