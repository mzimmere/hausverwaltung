#!/bin/sh
# Kein Root noetig: die App-Dateien liegen einfach im eigenen
# Paket-Sandbox-Ordner (SYNOPKG_PKGDEST/app). Web Station kann diesen
# Ordner nicht automatisch registrieren (das haette "conf/resource"
# gebraucht, was sich bei diesem Paket als nicht funktionierend
# herausgestellt hat) - stattdessen zeigt postinst hier den Pfad an,
# den man einmalig per File Station in den eigentlichen Web-Ordner
# kopieren muss.

{
    echo "Hausverwaltung wurde installiert - ein manueller Schritt fehlt noch:"
    echo ""
    echo "Die Programmdateien liegen bereit unter:"
    echo "  ${SYNOPKG_PKGDEST}/app"
    echo "(in File Station sichtbar unter 'appstore' -> 'HausVerwaltung' ->"
    echo "'target' -> 'app', falls noetig zuerst unter Ansicht -> Optionen"
    echo "'Versteckte Dateien anzeigen' aktivieren)"
    echo ""
    echo "Zwei Moeglichkeiten:"
    echo ""
    echo "A) Bestehende Installation aktualisieren:"
    echo "   Alles AUSSER config/config.php, uploads/ und backups/ in euren"
    echo "   bestehenden Ordner web/hausverwaltung kopieren (ueberschreiben)."
    echo "   Kein SQL-Schritt noetig, eure Datenbank bleibt wie sie ist."
    echo ""
    echo "B) Neue, eigenstaendige Installation:"
    echo "   Alles in einen NEUEN Ordner unter web/ kopieren, danach einmalig"
    echo "   EINMALIG_IN_PHPMYADMIN_AUSFUEHREN.sql in phpMyAdmin importieren"
    echo "   (Reiter Importieren, Datei auswaehlen, Los), danach loeschen."
    echo "   Login danach: admin / hausverwaltung (bitte sofort aendern)."
} > "$SYNOPKG_TEMP_LOGFILE" 2>/dev/null || true

exit 0
