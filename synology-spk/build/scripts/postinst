#!/bin/sh
# Kein Root noetig: die App-Dateien liegen einfach im eigenen
# Paket-Sandbox-Ordner (SYNOPKG_PKGDEST/app). Dieser Ordner ist NICHT
# ueber File Station erreichbar (auch nicht ueber "appstore" - das war
# ein frueherer Irrtum) - der Zugriff muss ueber SSH erfolgen. Getestet
# und bestaetigt funktionierend.

{
    echo "Hausverwaltung wurde installiert - ein manueller Schritt fehlt noch"
    echo "(per SSH, siehe Systemsteuerung -> Terminal & SNMP):"
    echo ""
    echo "A) Bestehende Installation aktualisieren (empfohlen):"
    echo "  sudo rsync -av --exclude 'config/config.php' --exclude 'uploads/' --exclude 'backups/' \\"
    echo "      ${SYNOPKG_PKGDEST}/app/ /volume1/web/hausverwaltung/"
    echo "  sudo chown -R http:http /volume1/web/hausverwaltung"
    echo "  (Pfad anpassen, falls eure Installation woanders liegt)"
    echo "  Kein SQL-Schritt noetig, eure Datenbank bleibt wie sie ist."
    echo ""
    echo "  Tipp: einmalig zusaetzlich ausfuehren, dann synct jedes kuenftige"
    echo "  Update automatisch (kein SSH-Schritt mehr noetig):"
    echo "    sudo chgrp -R http /volume1/web/hausverwaltung"
    echo "    sudo chmod -R g+rwX /volume1/web/hausverwaltung"
    echo "    sudo find /volume1/web/hausverwaltung -type d -exec chmod g+s {} \\;"
    echo ""
    echo "B) Neue, eigenstaendige Installation:"
    echo "  sudo mkdir -p /volume1/web/hausverwaltung_neu"
    echo "  sudo cp -r ${SYNOPKG_PKGDEST}/app/. /volume1/web/hausverwaltung_neu/"
    echo "  sudo chown -R http:http /volume1/web/hausverwaltung_neu"
    echo "  Danach einmalig EINMALIG_IN_PHPMYADMIN_AUSFUEHREN.sql aus diesem"
    echo "  neuen Ordner in phpMyAdmin importieren, danach loeschen."
    echo "  Login danach: admin / hausverwaltung (bitte sofort aendern)."
} > "$SYNOPKG_TEMP_LOGFILE" 2>/dev/null || true

exit 0
