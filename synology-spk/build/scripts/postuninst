#!/bin/sh
# Anders als bei einer klassischen (Root-)Installation wird der Webordner
# hier vom DSM-eigenen Webservice-Worker verwaltet (siehe conf/resource).
# Es ist NICHT sicher bekannt, ob web_packages/hausverwaltung beim
# Deinstallieren automatisch mitgeloescht wird oder erhalten bleibt -
# bitte vor dem Deinstallieren ein Backup ziehen, falls Daten wichtig sind.

{
    echo "Hausverwaltung wurde deinstalliert."
    echo "Die Datenbank 'hausverwaltung' bleibt in jedem Fall bestehen und"
    echo "muss bei Bedarf separat per phpMyAdmin geloescht werden."
} > "$SYNOPKG_TEMP_LOGFILE" 2>/dev/null || true

exit 0
