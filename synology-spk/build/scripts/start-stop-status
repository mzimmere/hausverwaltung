#!/bin/sh
# Statische PHP-Anwendung ohne eigenen Dienst - wird komplett von Web
# Station bedient. Es gibt hier nichts zu starten/stoppen; das Paket
# gilt als "laeuft", solange die Dateien vorhanden sind.

WEBROOT="/var/services/web/hausverwaltung"

case "$1" in
    start)
        exit 0
        ;;
    stop)
        exit 0
        ;;
    status)
        if [ -f "$WEBROOT/index.php" ]; then
            exit 0
        else
            exit 1
        fi
        ;;
    log)
        echo ""
        exit 0
        ;;
    *)
        exit 0
        ;;
esac
