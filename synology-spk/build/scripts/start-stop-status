#!/bin/sh
# Statische PHP-Anwendung ohne eigenen Dienst. Die Dateien liegen im
# eigenen Paket-Sandbox-Ordner (SYNOPKG_PKGDEST/app) - ob sie tatsaechlich
# irgendwo von Web Station bedient werden, haengt vom manuellen
# Kopierschritt aus postinst ab und laesst sich von hier aus nicht
# pruefen. Es gibt nichts zu starten/stoppen.

case "$1" in
    start)
        exit 0
        ;;
    stop)
        exit 0
        ;;
    status)
        if [ -f "${SYNOPKG_PKGDEST}/app/index.php" ]; then
            exit 0
        else
            exit 1
        fi
        ;;
    log)
        echo ""
        exit 0
        ;;
    *)
        exit 0
        ;;
esac
