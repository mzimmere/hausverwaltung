# Vorlage für die lokale Docker-Installation.
# Wird von start.bat / start.sh automatisch als ".env" mit zufälligen
# Passwörtern angelegt, falls noch keine ".env" existiert. Nur von Hand
# kopieren, wenn eigene Passwörter gesetzt werden sollen.

APP_PORT=8080
DB_NAME=hausverwaltung
DB_USER=hvuser
DB_PASS=bitte-aendern
DB_ROOT_PASS=bitte-aendern
